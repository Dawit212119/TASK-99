# Application
NODE_ENV=development
PORT=3000

# Database (MySQL)
DATABASE_URL=mysql://civicforum:civicforum@localhost:3306/civicforum

# Auth
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_EXPIRES_IN=8h

# Rate Limiting (in-memory)
RATE_LIMIT_WRITE_PER_MIN=120
RATE_LIMIT_READ_PER_MIN=600

# Auth lockout
LOGIN_LOCKOUT_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MINUTES=15

# Logging
LOG_LEVEL=info

# Internal API key — required for notification dispatch/retry endpoints.
# Set to any strong random string (openssl rand -hex 32).
# In development (NODE_ENV=development) it can be left blank to disable internal endpoints.
# In production, the app refuses to start unless this is set to a strong value (>= 32 chars).
INTERNAL_API_KEY=
